package com.Easyappln;

/*
 * Program Name : Number Pattern Printer
 * Author       : Tamilarasu K
 * Date         : 15-02-2026
 * Description  : This program prints the number pattern
 *                1
 *                2 2
 *                3 3 3
 *                ...
 *                up to N rows.
 */

import java.util.Scanner;

public class NumberPattern {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter the N value: ");
        int n = sc.nextInt();

        for (int i = 1; i <= n; i++) {

            for (int j = 1; j <= i; j++) {
                System.out.print(i + " ");
            }

            System.out.println();
        }

        sc.close();
    }
}
